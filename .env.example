# Copy this file to .env and fill in your keys

# Groq API key – used by the Interviewer agent
GROQ_API_KEY=your_groq_api_key_here

# Model identifiers (verify against provider catalog before use)
INTERVIEWER_MODEL=openai/gpt-oss-120b
EVALUATOR_MODEL=openai/gpt-oss-20b

# Optional: max tags injected per Interviewer prompt (cost guard)
MAX_TAGS_IN_PROMPT=80
